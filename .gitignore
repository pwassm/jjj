YTT

# FromCacheOld
FromCacheOld

# FromCache
FromCache

# (dev0451) cacheExtract.js output — clean image/video extracted from Firefox
# cache2 entries + the url→file manifest. Local staging, never committed.
FromCacheOut


# AHK
AHK

# Backup files
*.bak

# Deleted links archive (kept locally only)
deleted.json

# (dev0418) V "Choose" screen recordings — written to the project root by
# proxy.js /rec/*; kept local, never committed.
vsteps-*.mp4

# (dev0428/0429) IG harvest staging store + downloaded media — a LOCAL store
# parallel to ml.json, deliberately out of the public site. The I/Ig screen
# (ig.js) reads/writes ig.json locally; proxy.js /ig/download saves media to
# ig_media/. Kept local, never committed.
ig.json
ig_media/

# (dev0447) Bulk staging store — Flickr jpgs / YT / Vimeo / direct video links,
# parallel to ml.json and kept LOCAL until rows are Promoted into ml.json. Written
# by the St screen (s.js) via proxy /s/save. (*.bak is already ignored above.)
s.json
# (dev0450) Archive of rows deleted from s.json — appended by proxy /s/deleted so
# imports can avoid re-staging a previously-deleted link. Local only.
sdeleted.json

# (dev0454) "linkfinders" — standalone Python link-finder tools (imagefinder.py)
# and their imagelinks/ output + state. A deliberately NON-github local toolset
# that feeds the St screen via clipboard; never committed.
linkfinders/

# (dev0312) Local-media IndexedDB exports — privacy.
# Q's index (the localmedia IDB) lives in Chrome's profile, not in this repo:
#   %LOCALAPPDATA%\Google\Chrome\User Data\Default\IndexedDB\http_localhost_8080\
# These ignores are belt-and-suspenders against any future "export IDB to
# JSON" feature dumping into the project root.
q-export*.json
localmedia-export*.json
*.idb.json
*.idb.txt

